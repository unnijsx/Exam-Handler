{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://aiiii.wispbyte.org/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://aiiii.wispbyte.org/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}